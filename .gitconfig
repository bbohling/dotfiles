[init]
	defaultBranch = main
[alias]
	co = checkout
	ci = commit
	st = status
	br = branch
	hist = log --pretty=format:\"%h %ad | %s%d [%an]\" --graph --date=short
	type = cat-file -t
	dump = cat-file -p
	recent = for-each-ref --count=10 --sort=-committerdate refs/heads/ --format="%(refname:short)"
	overview = log --all --since='2 weeks' --oneline --no-merges
	graph = log --graph --all --decorate --stat --date=iso
	stats = shortlog -sn
[commit]
	gpgsign = true
[core]
	autocrlf = input
	safecrlf = warn
	editor = code --wait
	eol = lf
	excludesfile = ~/.gitignore
	longpaths = true
  packedGitLimit = 512m
  packedGitWindowSize = 512m
[color "branch"]
	current = yellow reverse
	local = yellow
	remote = green
[color "diff"]
	meta = yellow bold
	frag = magenta bold
	old = red bold
	new = green bold
[color "status"]
	added = yellow
	changed = green
	untracked = cyan
[credential]
	helper = osxkeychain
	useHttpPath = true
[difftool "Kaleidoscope"]
	cmd = ksdiff --partial-changeset --relative-path \"$MERGED\" -- \"$LOCAL\" \"$REMOTE\"
[diff]
	tool = Kaleidoscope
[difftool]
	prompt = false
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	required = true
[mergetool "Kaleidoscope"]
	cmd = ksdiff --merge --output \"$MERGED\" --base \"$BASE\" -- \"$LOCAL\" --snapshot \"$REMOTE\" --snapshot
	trustExitCode = true
[mergetool]
	prompt = false
[merge]
	tool = Kaleidoscope
	log = true
[pack]
  deltaCacheSize = 2047m
  packSizeLimit = 2047m
  windowMemory = 2047m
[pull]
	rebase = true
[push]
	default = simple
[tag]
	gpgsign = true
[url "https://github.com"]
  insteadOf = git://github.com
[user]
	name = bbohling
	email = brandon@bohling.me
	signingkey = 1A03FC211D0455B2

[merge "npm-merge-driver"]
	name = automatically merge npm lockfiles
	driver = npx npm-merge-driver merge %A %O %B %P

# Intel proxy for git over HTTPS (work repos). .gitconfig-personal unsets these.
# These MUST come before the [includeIf] blocks below — last write wins, and the
# personal include needs to land after the proxy URLs to override them.
[http]
	postBuffer = 1048576000
[http "https://github.com"]
	proxy = http://proxy-dmz.intel.com:912
[http "https://lfs.github.com"]
	proxy = http://proxy-dmz.intel.com:912
[http "https://github-cloud.s3.amazonaws.com"]
	proxy = http://proxy-dmz.intel.com:912
[http "https://github-cloud.githubusercontent.com"]
	proxy = http://proxy-dmz.intel.com:912

# Per-directory identity overrides — keep these at the bottom so they win.
# ~/excl/ contains work repos; ~/excl/🥃/ is personal. Order matters: the personal
# include comes after the work one so it wins for repos under ~/excl/🥃/.
[includeIf "gitdir:~/excl/"]
	path = ~/.dotfiles/.gitconfig-work
[includeIf "gitdir:~/excl/🥃/"]
	path = ~/.dotfiles/.gitconfig-personal
